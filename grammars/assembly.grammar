@top File { (Instr | Comment | Label | Reg | Decimal | Binary | Hex | Char)* }

@skip { space }

@tokens {
	space { @whitespace+ }
	Comment {";"![\n]*}
	Instr {$[A-Z]$[A-Z]$[A-Z]}
	Label {"."$[A-Za-z_]$[A-Za-z0-9_]*}
	Reg {"r"$[0-9]+}
	Binary {"0b"$[0-1]+}
	Hex {"0x"$[0-9A-Fa-f]+}
	Decimal {($[1-9]$[0-9]*) | "0" !["x" | "b"]}
	Char {"'"_"'"}
}