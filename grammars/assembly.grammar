@top File { (Instr | Comment | Label | Reg | Number | Char)* }

@skip { space }

@tokens {
	space { @whitespace+ }
	Comment {";"![\n]*}
	Instr {$[A-Z]$[A-Z]$[A-Z]}
	Label {"."$[A-Za-z_]$[A-Za-z0-9_]*}
	Reg {"r"$[0-9]+}
	Number {
    	@digit+ |
    	"0x" (@digit | $[a-fA-F])+ |
    	"0b" $[01]+ |
    	"0o" $[0-7]+
  	}
	Char {"'"_"'"}
}